modules = ["php-8.2", "nodejs-20", "web", "php-8.4"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_URL = "http://0.0.0.0:5000"
VITE_APP_NAME = "Laravel"
DB_CONNECTION = "mysql"
DB_HOST = "127.0.0.1"
DB_PORT = "3306"
DB_DATABASE = "laravel_chat"
DB_USERNAME = "laravel"
DB_PASSWORD = "secret"
BROADCAST_CONNECTION = "reverb"
REVERB_HOST = "localhost"
REVERB_PORT = "8080"
REVERB_SCHEME = "http"
SESSION_DRIVER = "file"
QUEUE_CONNECTION = "sync"
CACHE_STORE = "file"
DB_SOCKET = "/home/runner/.mysql/run/mysql.sock"
VITE_REVERB_APP_KEY = "${REVERB_APP_KEY}"
VITE_REVERB_HOST = "${REVERB_HOST}"
VITE_REVERB_PORT = "${REVERB_PORT}"
VITE_REVERB_SCHEME = "${REVERB_SCHEME}"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 3306
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["php", "artisan", "serve", "--host=0.0.0.0", "--port=5000"]
build = ["bash", "-c", "composer install --no-dev --optimize-autoloader && npm run build && php artisan config:cache && php artisan route:cache && php artisan view:cache"]
